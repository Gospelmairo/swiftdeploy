networks:
  {{ network.name }}:
    driver: {{ network.driver_type }}

volumes:
  app-logs:
    driver: local

services:
  app:
    image: {{ services.image }}
    restart: {{ services.restart_policy }}
    networks:
      - {{ network.name }}
    environment:
      - MODE={{ services.mode }}
      - APP_VERSION={{ services.version }}
      - APP_PORT={{ services.port }}
    volumes:
      - app-logs:/var/log/app
    expose:
      - "{{ services.port }}"
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{{ services.port }}/healthz')"]
      interval: 15s
      timeout: 5s
      retries: 3
      start_period: 10s
    security_opt:
      - no-new-privileges:true

  nginx:
    image: {{ nginx.image }}
    restart: {{ services.restart_policy }}
    networks:
      - {{ network.name }}
    ports:
      - "{{ nginx.port }}:{{ nginx.port }}"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf
      - app-logs:/var/log/nginx
    depends_on:
      app:
        condition: service_healthy
